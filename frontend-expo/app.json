{
  "expo": {
    "name": "lapsphere",
    "slug": "lapsphere",
    "scheme": [
      "com.lapsphere.itcp239.dev",
      "com.googleusercontent.apps.1061265006776-8k5hac1d8h9flh8l9pripeh18n9m1fsg"
    ],
    "owner": "kuronini7",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.lapsphere.itcp239",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "bef03e61-bc14-47d0-a447-8684a592ec18"
      },
      "apiUrl": "http://192.168.1.36:4000"
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ]
    ]
  }
}
