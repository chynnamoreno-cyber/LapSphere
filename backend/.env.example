NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CONNECTION_STRING=mongodb+srv://username:password@cluster/database?retryWrites=true&w=majority
DB_NAME=ITCP_database
JWT_SECRET=your-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
FCM_SERVICE_ACCOUNT_PATH=path/to/firebase-service-account.json

# [MP2] Google sign-in (optional). Get credentials from Google Cloud Console.
# Use GOOGLE_CLIENT_IDS for multiple client IDs (comma-separated).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
